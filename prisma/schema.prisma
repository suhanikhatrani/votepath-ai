generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String        @id @default(uuid())
  name             String
  email            String        @unique
  age              Int
  state            String
  language         String        @default("en")
  registeredStatus Boolean       @default(false)
  reminders        Reminder[]
  chatHistory      ChatHistory[]
}

model Reminder {
  id      String   @id @default(uuid())
  userId  String
  title   String
  date    DateTime
  user    User     @relation(fields: [userId], references: [id])
}

model ChatHistory {
  id        String   @id @default(uuid())
  userId    String
  question  String
  answer    String
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
